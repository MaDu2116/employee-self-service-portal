{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./prisma",
    "outDir": "./dist/seed",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["prisma/seed.ts"]
}
